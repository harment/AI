DB_HOST=localhost
DB_PORT=3306
DB_NAME=dhakali_db
DB_USER=root
DB_PASS=

# =============================================
# مفاتيح الذكاء الاصطناعي
# =============================================
# احصل على مفتاح Gemini المجاني من:
# https://aistudio.google.com/app/apikey
# انسخ هذا الملف إلى .env وأدخل مفتاحك:
GEMINI_API_KEY=
OPENAI_API_KEY=
# احصل على مفتاح Claude من: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# احصل على مفتاح Gamma من: https://gamma.app/
GAMMA_API_KEY=
